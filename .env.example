# === Anthropic API keys ===
# Enterprise Analytics API key (sk-ant-api01-... with Analytics scope) — required for live mode.
ANTHROPIC_ANALYTICS_KEY=sk-ant-api01-your-key-here

# Optional Admin API key (sk-ant-admin01-...) — enables the Cost page's token/model breakdown.
ANTHROPIC_ADMIN_KEY_ADMIN=

# Optional Compliance API key (sk-ant-api01-... with Compliance scope) — enables the Audit page.
ANTHROPIC_COMPLIANCE_KEY=

ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
PORT=5174

# === AWS ===
AWS_REGION=ap-northeast-2
# Bedrock model: a cross-region inference profile works in any region.
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# Archive bucket (the compute stack exports this; fill in for local dev if you want CSV / archive features)
ARCHIVE_S3_BUCKET=
ATHENA_WORKGROUP=claude-code-dashboard
ATHENA_DATABASE=claude_code_analytics
ATHENA_OUTPUT_LOCATION=s3://your-archive-bucket/athena-results/

# === Optional hook webhooks ===
# Slack webhook for the .claude/hooks/notify.sh hook
CCD_SLACK_WEBHOOK=
